{
  "openapi": "3.0.0",
  "info": {
    "title": "WHERE Backend API",
    "version": "1.0.0",
    "description": "A meetup networking application API with Sequelize ORM and PostgreSQL support",
    "contact": {
      "name": "WHERE Team",
      "url": "https://github.com/WHERE-Networking-App/Where-Backend"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Development server"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "API health check"
    },
    {
      "name": "Authentication",
      "description": "User authentication endpoints"
    },
    {
      "name": "Users",
      "description": "User management and profile endpoints"
    },
    {
      "name": "Meetups",
      "description": "Meetup creation and management endpoints"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Enter your JWT token"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/": {
      "get": {
        "summary": "API Health Check",
        "description": "Returns API status and version information",
        "tags": ["Health"],
        "responses": {
          "200": {
            "description": "API is running",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "WHERE Backend API" },
                    "version": { "type": "string", "example": "1.0.0" },
                    "status": { "type": "string", "example": "running" },
                    "documentation": { "type": "string", "example": "/api-docs" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/signup": {
      "post": {
        "summary": "Register a new user",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "user@example.com" },
                  "password": { "type": "string", "minLength": 6, "example": "password123" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "token": { "type": "string" },
                    "userId": { "type": "integer" },
                    "setupCompleted": { "type": "boolean" }
                  }
                }
              }
            }
          },
          "400": { "description": "Validation error or email already registered" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login user",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "user@example.com" },
                  "password": { "type": "string", "example": "password123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/users/interests/categories": {
      "get": {
        "summary": "Get all interest categories",
        "tags": ["Users"],
        "responses": {
          "200": { "description": "List of interest categories" }
        }
      }
    },
    "/api/users/setup/step1": {
      "post": {
        "summary": "Complete profile setup step 1",
        "tags": ["Users"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "inAppName", "profession"],
                "properties": {
                  "username": { "type": "string", "example": "johndoe" },
                  "inAppName": { "type": "string", "example": "John" },
                  "profession": { "type": "string", "example": "Software Developer" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Step 1 completed successfully" },
          "400": { "description": "Validation error or username taken" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/users/setup/step2": {
      "post": {
        "summary": "Complete profile setup step 2 (Add interests)",
        "tags": ["Users"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["interests"],
                "properties": {
                  "interests": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "category": { "type": "string", "example": "Music" },
                        "interest": { "type": "string", "example": "Indie" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Setup completed successfully" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/users/profile": {
      "get": {
        "summary": "Get user profile",
        "tags": ["Users"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "User profile data" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "User not found" }
        }
      }
    },
    "/api/meetups/create": {
      "post": {
        "summary": "Create a new meetup",
        "tags": ["Meetups"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "date", "timeSlot", "city", "vibe", "participantsLimit"],
                "properties": {
                  "title": { "type": "string", "example": "Coffee Meetup in NYC" },
                  "description": { "type": "string", "example": "Let's grab coffee" },
                  "date": { "type": "string", "format": "date", "example": "2026-04-15" },
                  "timeSlot": { "type": "string", "enum": ["Morning", "Noon", "Evening", "Night"], "example": "Morning" },
                  "city": { "type": "string", "example": "New York" },
                  "location": { "type": "string", "example": "Central Park Cafe" },
                  "vibe": { "type": "string", "enum": ["Coffee", "Beer", "Coworking"], "example": "Coffee" },
                  "participantsLimit": { "type": "integer", "minimum": 2, "maximum": 50, "example": 5 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Meetup created successfully" },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/meetups/upcoming": {
      "get": {
        "summary": "Get all upcoming meetups",
        "tags": ["Meetups"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "List of upcoming meetups" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/meetups/{id}": {
      "get": {
        "summary": "Get meetup details",
        "tags": ["Meetups"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Meetup ID"
          }
        ],
        "responses": {
          "200": { "description": "Meetup details with participants" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Meetup not found" }
        }
      }
    },
    "/api/meetups/{id}/join": {
      "post": {
        "summary": "Join a meetup",
        "tags": ["Meetups"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Successfully joined meetup" },
          "400": { "description": "Already joined or meetup is full" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/meetups/{id}/leave": {
      "post": {
        "summary": "Leave a meetup",
        "tags": ["Meetups"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Successfully left meetup" },
          "400": { "description": "Not a participant" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/meetups/{id}/cancel": {
      "post": {
        "summary": "Cancel a meetup (host only)",
        "tags": ["Meetups"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Meetup cancelled successfully" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Only host can cancel" }
        }
      }
    },
    "/api/meetups/{id}/reach": {
      "post": {
        "summary": "Mark as reached (on meetup day)",
        "tags": ["Meetups"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "note": { "type": "string", "example": "I'll arrive around 4:10" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Marked as reached successfully" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Only participants can mark as reached" }
        }
      }
    }
  }
}
